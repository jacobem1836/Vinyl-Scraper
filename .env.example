# Discogs API — get your free token at discogs.com/settings/developers
DISCOGS_TOKEN=your_discogs_token_here

# API key — used by the iOS Shortcut to authenticate. Change this to something random.
API_KEY=change-me-to-a-random-secret

# Database — SQLite by default. For Railway production, set to a PostgreSQL URL.
DATABASE_URL=sqlite:///./vinyl.db

# Email notifications — iCloud SMTP
# Get an App-Specific Password at appleid.apple.com > Sign-In & Security > App-Specific Passwords
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=your_apple_id@icloud.com
SMTP_PASSWORD=your_app_specific_password
NOTIFY_EMAIL=email_to_receive_notifications@example.com

# How often to scan for new deals (in hours)
SCAN_INTERVAL_HOURS=6
